#!/bin/sh
# Self-extracting fat binary. Detects OS/arch, extracts the right platform
# binary from the tarball appended after the __ARCHIVE__ marker, caches it
# in a version-tagged directory, and execs it.
set -e
GRADLE_CACHE_VERSION="__VERSION__"
OS=$(uname -s | tr '[:upper:]' '[:lower:]')
ARCH=$(uname -m)
case $ARCH in
    x86_64)  ARCH=amd64 ;;
    aarch64|arm64) ARCH=arm64 ;;
    *) echo "error: unsupported architecture: $ARCH" >&2; exit 1 ;;
esac
case $OS in
    linux|darwin) ;;
    *) echo "error: unsupported OS: $OS" >&2; exit 1 ;;
esac
CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/gradle-cache-tool/$GRADLE_CACHE_VERSION"
BIN="$CACHE/gradle-cache-${OS}-${ARCH}"
if [ ! -x "$BIN" ]; then
    mkdir -p "$CACHE"
    SKIP=$(awk '/^__ARCHIVE__$/{print NR+1; exit}' "$0")
    tail -n +"$SKIP" "$0" | tar xzf - -C "$CACHE" "gradle-cache-${OS}-${ARCH}"
fi
exec "$BIN" "$@"
__ARCHIVE__
